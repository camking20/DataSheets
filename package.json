{
  "name": "datasheets",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @datasheets/db generate",
    "db:migrate": "pnpm --filter @datasheets/db migrate",
    "db:studio": "pnpm --filter @datasheets/db studio",
    "db:seed": "pnpm --filter @datasheets/db seed"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
